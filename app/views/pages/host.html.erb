<div class="container py-4">
  <%= render "shared/ui/page_header", title: t("pages.host.title") %>

  <div class="card lv-card">
    <div class="card-body prose lv-host">
      <figure class="lv-host__photo">
        <%= image_tag(
          ENV.fetch(
            "HOST_DEFAULT_IMAGE_URL",
            "https://raw.githubusercontent.com/lewagon/fullstack-images/master/uikit/breakfast.jpg"
          ),
          class: "img-fluid",
          alt: t("pages.host.image_alt"),
          loading: "lazy",
          decoding: "async"
        ) %>
      </figure>

      <h2><%= t("pages.host.section_title") %></h2>
      <p><%= t("pages.host.body.p1") %></p>
      <p><%= t("pages.host.body.p2") %></p>
      <p><%= t("pages.host.body.p3") %></p>
      <p><%= t("pages.host.body.p4") %></p>
    </div>
  </div>
</div>

<div class="container py-4">
  <% content_for :title, "#{t('pages.legal.title')} · #{t('app.title')}" %>
  <% content_for :meta_description, t('pages.legal.title') %>
  <%= render "shared/ui/page_header", title: t("pages.legal.title") %>

  <div class="card lv-card">
    <div class="card-body prose">
      <h2><%= t("pages.legal.publisher.title") %></h2>
      <ul>
        <li><strong><%= t("pages.legal.publisher.name") %></strong> <%= @publisher_name.presence || t("pages.legal.not_provided") %></li>
        <li><strong><%= t("pages.legal.publisher.address") %></strong> <%= @publisher_address.presence || t("pages.legal.not_provided") %></li>
        <li><strong><%= t("pages.legal.publisher.email") %></strong> <%= @publisher_email.presence || t("pages.legal.not_provided") %></li>
      </ul>

      <h2><%= t("pages.legal.host.title") %></h2>
      <ul>
        <li><strong><%= t("pages.legal.host.name") %></strong> Heroku</li>
        <li><strong><%= t("pages.legal.host.address") %></strong> <%= safe_join([
          "Salesforce",
          "415 Mission Street",
          "Suite 300",
          "San Francisco, CA",
          "94105"
        ], tag.br) %></li>
        <li><strong><%= t("pages.legal.host.contact") %></strong> <%= link_to("https://www.heroku.com/contact/", "https://www.heroku.com/contact/", target: "_blank", rel: "noopener") %></li>
      </ul>

      <h2><%= t("pages.legal.ip.title") %></h2>
      <p><%= t("pages.legal.ip.body") %></p>

      <h2><%= t("pages.legal.data.title") %></h2>
      <p><%= t("pages.legal.data.body") %></p>

      <h2><%= t("pages.legal.cookies.title") %></h2>
      <p><%= t("pages.legal.cookies.body") %></p>

      <h2><%= t("pages.legal.contact.title") %></h2>
      <p><%= t("pages.legal.contact.body") %></p>
    </div>
  </div>

  <div class="mt-3">
    <%= link_to t("pages.legal.back"), root_path, class: "btn btn-soft" %>
  </div>
</div>

<% prechecked_optional_service_names = Array(params.dig(:booking, :optional_service_names)).map(&:to_s) %>

<div class="container py-4">
  <%= render "shared/ui/page_header",
    title: t(".title", room: @room.name),
    subtitle: t(".process_hint") %>

  <div class="row g-4 mt-1">
    <%# Room preview (fills space on desktop, stacks on mobile). %>
    <div class="col-12 col-lg-5">
      <% preview_url = nil %>
      <% if @room.photos.attached? %>
        <% preview_url = url_for(@room.photos.first) %>
      <% elsif @room.image_urls.any? %>
        <% preview_url = @room.image_urls.first %>
      <% else %>
        <% preview_url = "https://raw.githubusercontent.com/lewagon/fullstack-images/master/uikit/greece.jpg" %>
      <% end %>

      <div class="card lv-card overflow-hidden h-100">
        <%= image_tag preview_url,
          alt: t(".room_preview_alt", room: @room.name),
          class: "w-100",
          style: "object-fit: cover; height: 320px;" %>
        <div class="card-body">
          <div class="h5 mb-1"><%= @room.name %></div>
          <% if @room.description.present? %>
            <div class="text-muted"><%= truncate(@room.description.to_s, length: 160) %></div>
          <% end %>
        </div>
      </div>
    </div>

    <div class="col-12 col-lg-7">
      <div class="card lv-card">
        <div class="card-body">
          <div class="card lv-card lv-card--soft p-3 mb-3">
            <div class="d-flex align-items-start gap-2">
              <div class="text-uppercase lv-muted small"><%= t(".important") %></div>
            </div>
            <div class="mt-1"><%= t(".no_payment_notice") %></div>
          </div>

          <%= form_with model: [@room, @booking], data: { controller: "required-fields booking-form-persist", booking_form_persist_key_value: "room-#{@room.id}" } do |f| %>
            <% if @booking.errors.any? %>
              <div class="alert alert-danger mb-3">
                <ul class="mb-0">
                  <% @booking.errors.full_messages.each do |msg| %>
                    <li><%= msg %></li>
                  <% end %>
                </ul>
              </div>
            <% end %>

            <div class="row g-3">
              <div class="col-12 col-md-6">
                <%= f.label :start_date, t(".start_date"), class: "form-label" %>
                <%= f.text_field :start_date, class: "form-control", data: { controller: "flatpickr" } %>
              </div>

              <div class="col-12 col-md-6">
                <%= f.label :end_date, t(".end_date"), class: "form-label" %>
                <%= f.text_field :end_date, class: "form-control", data: { controller: "flatpickr" } %>
              </div>
            </div>

            <% if Array(@room.optional_services).any? %>
              <hr class="my-3 lv-divider" />

              <div class="mb-3">
                <div class="text-uppercase lv-muted small"><%= t(".optional_services.title") %></div>
                <div class="d-grid gap-2 mt-2">
                  <% Array(@room.optional_services).each do |service| %>
                    <% next unless service.is_a?(Hash) %>
                    <% name = (service["name"] || service[:name]).to_s.strip %>
                    <% price_cents = service["price_cents"] || service[:price_cents] %>
                    <% next if name.blank? || price_cents.blank? %>

                    <% checked = prechecked_optional_service_names.include?(name) %>

                    <div class="form-check d-flex justify-content-between align-items-center">
                      <div>
                        <%= check_box_tag "booking[optional_service_names][]", name, checked, id: "booking_optional_service_#{name.parameterize}", class: "form-check-input" %>
                        <%= label_tag "booking_optional_service_#{name.parameterize}", name, class: "form-check-label" %>
                      </div>
                      <div class="text-muted"><%= format_price_euros(price_cents) %></div>
                    </div>
                  <% end %>
                </div>
                <div class="form-text"><%= t(".optional_services.hint") %></div>
              </div>
            <% end %>

            <hr class="my-3 lv-divider" />

            <div class="mb-3 lv-terms-check">
              <div class="form-check">
                <%= f.check_box :accepts_terms,
                  class: "form-check-input",
                  data: { action: "change->required-fields#update", "required-fields-target": "required" } %>
                <%= f.label :accepts_terms, class: "form-check-label" do %>
                  <%= sanitize(
                    t(
                      ".accept_terms_html",
                      cgv_link: link_to(t(".cgv_link_text"), cgv_path(return_to: request.fullpath), target: "_blank", rel: "noopener")
                    ),
                    tags: %w[a],
                    attributes: %w[href target rel]
                  ) %>
                <% end %>
              </div>
            </div>

            <%= f.submit t(".submit"), class: "btn btn-accent w-100", disabled: true, data: { "required-fields-target": "submit" } %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
